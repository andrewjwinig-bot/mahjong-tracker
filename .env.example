# Club Mahj — environment variables. Copy to .env.local for dev, or set these
# in Vercel (Project → Settings → Environment Variables) for production.
# Everything is optional: with none set, the app runs 100% on-device in demo mode.

# --- Demo vs. real data -----------------------------------------------------
# '1' = force demo (seeded friends/feed/tables), '0' = force real (empty until
# you create content). Unset = demo by default. Set to 0 for the launch build.
NEXT_PUBLIC_DEMO_MODE=1

# --- Supabase (accounts, cloud sync, social, friends) -----------------------
# From your Supabase project → Settings → API. Leaving these blank keeps the
# app fully on-device (no auth, no cloud). See docs/backend.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- In-app purchase (RevenueCat, native builds only) -----------------------
# Public RevenueCat SDK key. Only used inside the native Capacitor shell; the
# web build ignores it and previews Pro with the local flag. See app/lib/billing.ts.
NEXT_PUBLIC_REVENUECAT_KEY=

# --- Native wrapper ---------------------------------------------------------
# Production URL the Capacitor shell loads (see capacitor.config.ts).
CAP_SERVER_URL=https://clubmahj.com
